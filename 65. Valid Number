class Solution {
    public boolean isNumber(String s) {
        s = s.trim();

        boolean numSeen = false;
        boolean dotSeen = false;
        boolean eSeen = false;
        boolean numAfterE = true;

        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);

            if (Character.isDigit(ch)) {
                numSeen = true;
                numAfterE = true;
            } 
            else if (ch == '+' || ch == '-') {
                // valid only at start or after e/E
                if (i > 0 && s.charAt(i - 1) != 'e' && s.charAt(i - 1) != 'E') {
                    return false;
                }
            } 
            else if (ch == '.') {
                // dot only once and not after e
                if (dotSeen || eSeen) return false;
                dotSeen = true;
            } 
            else if (ch == 'e' || ch == 'E') {
                // e only once and must have number before it
                if (eSeen || !numSeen) return false;
                eSeen = true;
                numAfterE = false;
            } 
            else {
                return false;
            }
        }

        return numSeen && numAfterE;
    }
}
